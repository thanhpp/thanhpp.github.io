{"pageProps":{"note":{"id":"usgdkk51sx7nsnus0b34r2q","title":"Habit Stacking","desc":"","updated":1662573021649,"created":1662480869303,"custom":{},"fname":"selfhelp.habit-stacking","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"278c743453eaef457f3e9474b2a18921","links":[],"anchors":{"habit-stacking":{"type":"header","text":"Habit stacking","value":"habit-stacking","line":8,"column":0,"depth":1},"minimal-habits":{"type":"header","text":"Minimal habits","value":"minimal-habits","line":12,"column":0,"depth":2},"overlapping-tasks":{"type":"header","text":"Overlapping tasks","value":"overlapping-tasks","line":22,"column":0,"depth":2},"summarize":{"type":"header","text":"Summarize","value":"summarize","line":34,"column":0,"depth":2}},"children":[],"parent":"sencgim78q74o1zuyvy1vz7","data":{}},"body":"<h1 id=\"habit-stacking\">Habit Stacking<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#habit-stacking\"></a></h1>\n<h1 id=\"habit-stacking-1\">Habit stacking<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#habit-stacking-1\"></a></h1>\n<blockquote>\n<p><a href=\"https://youtu.be/OPw7HODLAyM\">https://youtu.be/OPw7HODLAyM</a></p>\n</blockquote>\n<h2 id=\"minimal-habits\">Minimal habits<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#minimal-habits\"></a></h2>\n<ul>\n<li>Setting a commitment to do a paticular habit (but a lot <strong>less than ideally</strong>)\n<ul>\n<li>Example: not a full routine workout everyday -> 50 push-ups <strong>everyday</strong></li>\n</ul>\n</li>\n<li>smaller commitments</li>\n<li>To create a foundation/base line</li>\n<li>The hardest part: initialization</li>\n<li>Focus on the frenquency, don't break the chain</li>\n<li>GOAL: <strong>maintain consistency</strong></li>\n</ul>\n<h2 id=\"overlapping-tasks\">Overlapping tasks<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#overlapping-tasks\"></a></h2>\n<ul>\n<li>Stacking habits</li>\n<li>Example\n<ul>\n<li>Learning languages &#x26; reading</li>\n<li>Listening &#x26; workout</li>\n</ul>\n</li>\n<li>Strategies\n<ul>\n<li>spliting tasks: physical &#x26; cognitive/using mind => merge 1 and other</li>\n<li>split by different cognitive mechanism\n<ul>\n<li>visual task</li>\n<li>listen task</li>\n</ul>\n</li>\n</ul>\n</li>\n</ul>\n<h2 id=\"summarize\">Summarize<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#summarize\"></a></h2>\n<ul>\n<li>Minimal habit: do low effort tasks to maintain consistency</li>\n<li>Overlapping: Reduce time by combining tasks</li>\n</ul>","noteIndex":{"id":"xfkxbponh0sohobo6pual15","title":"Root","desc":"","updated":1668137379975,"created":1663481872547,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"cb44915142ec96bef8f764f3dc90389e","links":[],"anchors":{"welcome-to-my-page":{"type":"header","text":"Welcome to my page","value":"welcome-to-my-page","line":7,"column":0,"depth":1},"contacts":{"type":"header","text":"Contacts","value":"contacts","line":12,"column":0,"depth":2},"dendron":{"type":"header","text":"Dendron","value":"dendron","line":18,"column":0,"depth":2}},"children":["u5a2e2vvfn3x7k0shuvmb1b","qw8y69zxn8wr7tzz4gtcrrv","q7qw45jglqwmynary64q67c","6wjqcjgkrpeqtmzb1o8o1q8","3ervbn5we7t8v2l2vwtx847","4qi2z0z9fquupbd651xausx","sencgim78q74o1zuyvy1vz7","ue4oml1si982t3mmbthyxi9","zrogwjgtze8ne5joqpz8ty9","oesia0lbzh03fsoy124ck0k","el3p9zjue6h3b6zsl9oejkt","t5grkmcwvu4nl43igsj4gxz"],"parent":null,"data":{},"body":"# Welcome to my page\n\n- This is a place where I write my knowledge in both Vietnamese and English.\n- Please feel free to correct me if there is anything not right.\n\n## Contacts\n\n- [Github](https://github.com/thanhpp)\n- [Discord](https://discord.gg/ugNRjFNqjp)\n- [LinkedIn](https://www.linkedin.com/in/thanhpp/)\n\n## Dendron\n\n- [Home Page](https://wiki.dendron.so/)"},"collectionChildren":null,"cust