{"pageProps":{"note":{"id":"u35q71uwtvqy41vrbd5pmit","title":"I3","desc":"","updated":1661063878218,"created":1661055610666,"custom":{},"fname":"linux.customization.i3","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"ccf08eff3870b55c1c6993ace8281988","links":[{"from":{"fname":"linux.customization.install-checklist","id":"6heqjju0cm02y0rjgk9kajk","vaultName":"docs"},"type":"backlink","position":{"start":{"line":4,"column":7,"offset":34},"end":{"line":4,"column":33,"offset":60},"indent":[]},"value":"linux.customization.i3"},{"from":{"fname":"linux.customization.i3.hiDPI","id":"aswyqkz89eftmbljy0uz8ht","vaultName":"docs"},"type":"backlink","position":{"start":{"line":2,"column":10,"offset":10},"end":{"line":2,"column":36,"offset":36},"indent":[]},"value":"linux.customization.i3"}],"anchors":{"i3-is-a-window-tilting-manager":{"type":"header","text":"i3 is a window tilting manager","value":"i3-is-a-window-tilting-manager","line":8,"column":0,"depth":1},"install-i3":{"type":"header","text":"Install i3","value":"install-i3","line":10,"column":0,"depth":2},"config":{"type":"header","text":"Config","value":"config","line":16,"column":0,"depth":2},"uninstall":{"type":"header","text":"Uninstall","value":"uninstall","line":24,"column":0,"depth":2}},"children":["kf9ce7bxm51l2lu4xgnq679","aswyqkz89eftmbljy0uz8ht","bsapx5j9awppirs1af4ccvr"],"parent":"0dcz8bz1ladgjebaljq61w7","data":{}},"body":"<h1 id=\"i3\">I3<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#i3\"></a></h1>\n<h1 id=\"i3-is-a-window-tilting-manager\">i3 is a window tilting manager<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#i3-is-a-window-tilting-manager\"></a></h1>\n<h2 id=\"install-i3\">Install i3<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#install-i3\"></a></h2>\n<ul>\n<li><a href=\"https://i3wm.org/downloads/\">homepage</a></li>\n<li>Install through apt</li>\n<li>remember to add the gnome-keyring.deb</li>\n</ul>\n<h2 id=\"config\">Config<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#config\"></a></h2>\n<ul>\n<li>placed in <code>$HOME/.config/i3</code> (can be a soft link)</li>\n<li>scripts\n<ul>\n<li>i3exit: lock, suspend, shutdown</li>\n</ul>\n</li>\n<li>backgrounds</li>\n<li>command <code>ln -s /home/thanhpp/go/src/github.com/thanhpp/Ubuntu_Settings/settings/i3 /home/thanhpp/.config/i3</code>   </li>\n</ul>\n<h2 id=\"uninstall\">Uninstall<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#uninstall\"></a></h2>\n<p><code>sudo apt-get remove i3; sudo apt-get purge i3; sudo apt-get autoremove; sudo apt-get autoclean</code></p>\n<p><code>sudo apt remove i3-wm and i3-wm-dbg</code></p>\n<hr>\n<strong>Children</strong>\n<ol>\n<li><a href=\"/notes/kf9ce7bxm51l2lu4xgnq679\">Gnome Dark Theme</a></li>\n<li><a href=\"/notes/bsapx5j9awppirs1af4ccvr\">Natural Scroll</a></li>\n<li><a href=\"/notes/aswyqkz89eftmbljy0uz8ht\">hiDPI</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/notes/6heqjju0cm02y0rjgk9kajk\">Install Checklist</a></li>\n<li><a href=\"/notes/aswyqkz89eftmbljy0uz8ht\">hiDPI</a></li>\n</ul>","noteIndex":{"id":"xfkxbponh0sohobo6pual15","title":"Root","desc":"","updated":1668137379975,"created":1663481872547,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"cb44915142ec96bef8f764f3dc90389e","links":[],"anchors":{"welcome-to-my-page":{"type":"header","text":"Welcome to my page","value":"welcome-to-my-page","line":7,"column":0,"depth":1},"contacts":{"type":"header","text":"Contacts","value":"contacts","line":12,"column":0,"depth":2},"dendron":{"type":"header","text":"Dendron","value":"dendron","line":18,"column":0,"depth":2}},"children":["u5a2e2vvfn3x7k0shuvmb1b","qw8y69zxn8wr7tzz4gtcrrv","q7qw45jglqwmynary64q67c","6wjqcjgkrpeqtmzb1o8o1q8","3ervbn5we7t8v2l2vwtx847","4qi2z0z9fquupbd651xausx","sencgim78q74o1zuyvy1vz7","ue4oml1si982t