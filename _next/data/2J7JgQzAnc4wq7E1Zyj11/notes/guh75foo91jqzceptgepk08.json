{"pageProps":{"note":{"id":"guh75foo91jqzceptgepk08","title":"Scuba","desc":"","updated":1669191809384,"created":1669190670892,"custom":{},"fname":"system-design.Scuba","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"88794b4fde3faf9771a26010c23f9ae1","links":[],"anchors":{"scuba---metas-monitoring-system":{"type":"header","text":"Scuba - Meta's monitoring system","value":"scuba---metas-monitoring-system","line":7,"column":0,"depth":1},"intro":{"type":"header","text":"Intro","value":"intro","line":13,"column":0,"depth":2},"architecture":{"type":"header","text":"Architecture","value":"architecture","line":28,"column":0,"depth":2},"ui":{"type":"header","text":"UI","value":"ui","line":38,"column":0,"depth":2},"integration":{"type":"header","text":"Integration","value":"integration","line":44,"column":0,"depth":2}},"children":[],"parent":"ue4oml1si982t3mmbthyxi9","data":{}},"body":"<h1 id=\"scuba\">Scuba<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#scuba\"></a></h1>\n<h1 id=\"scuba---metas-monitoring-system\">Scuba - Meta's monitoring system<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#scuba---metas-monitoring-system\"></a></h1>\n<blockquote>\n<p><a href=\"https://research.facebook.com/file/2964294030497318/scuba-diving-into-data-at-facebook.pdf\">https://research.facebook.com/file/2964294030497318/scuba-diving-into-data-at-facebook.pdf</a>\n<a href=\"https://www.facebook.com/notes/10158791569947200\">https://www.facebook.com/notes/10158791569947200</a>\n<a href=\"https://news.ycombinator.com/item?id=13463016\">https://news.ycombinator.com/item?id=13463016</a></p>\n</blockquote>\n<h2 id=\"intro\">Intro<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#intro\"></a></h2>\n<ul>\n<li>Scuba\n<ul>\n<li>Realtime database: fast &#x26; scalable</li>\n<li>Ingestion framework: low latency </li>\n<li>Detectors framework: set up alert &#x26; detect metrics</li>\n<li>Query tools</li>\n</ul>\n</li>\n<li>Trade-offs\n<ul>\n<li>no joins, no global sorting -> need to use another tool</li>\n<li>flat schema (no nested)</li>\n<li>no consistency (best effort)</li>\n<li>Time partition only</li>\n<li>Time &#x26; Space retention limits (only serve in a limited range of time)</li>\n<li>not 4 high traffic</li>\n</ul>\n</li>\n</ul>\n<h2 id=\"architecture\">Architecture<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#architecture\"></a></h2>\n<p><img src=\"/assets/2022-11-23_15-11-scube-architecture.png\"></p>\n<ul>\n<li>\n<p>Scuba UI: using SQL</p>\n</li>\n<li>\n<p>Fast query</p>\n<ul>\n<li><img src=\"/assets/2022-11-23_15-13-scuba-fast-query.png\" alt=\"Fast Query\"></li>\n<li>Divide a query to multiple nodes, data is splitted by levels</li>\n</ul>\n</li>\n</ul>\n<h2 id=\"ui\">UI<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#ui\"></a></h2>\n<ul>\n<li>Usecase: Monitor code performance \n<ul>\n<li>compares latency by weeks </li>\n</ul>\n</li>\n<li>Each diagram is built from a single table (no joins supported)</li>\n</ul>\n<h2 id=\"integration\">Integration<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#integration\"></a></h2>\n<ul>\n<li>Scuba: Realtime database + UI + ingestion framework</li>\n<li>Strong point: pre-built supported metrics (created by the data team)</li>\n<li>Profiling: \n<ul>\n<li>dump linux stack trace -> data</li>\n<li>the service team doesn't need to update their code</li>\n</ul>\n</li>\n</ul>","noteIndex":{"id":"xfkxbponh0sohobo6pual15","title":"Root","desc":"","updated":1668137379975,"created":1663481872547,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"cb44915142ec96bef8f764f3dc90389e","links":[],"anchors":{"welcome-to-my-page":{"type":"header","text":"Welcome to my page","value":"welcome-to-my-page","line":7,"column":0,"depth":1},"contacts":{"type":"header","text":"Contacts","value":"contacts