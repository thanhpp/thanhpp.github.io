{"pageProps":{"note":{"id":"ct2spb1vqxg4baqenuf40as","title":"Sway","desc":"","updated":1663606040508,"created":1663483434511,"custom":{},"fname":"linux.customization.sway","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"3e3babdfeee8e644ad49e8ee9363c778","links":[],"anchors":{"sway---i3-compatible-wayland-compositor":{"type":"header","text":"Sway - i3-compatible Wayland compositor","value":"sway---i3-compatible-wayland-compositor","line":8,"column":0,"depth":1},"install":{"type":"header","text":"Install","value":"install","line":19,"column":0,"depth":2},"config":{"type":"header","text":"Config","value":"config","line":25,"column":0,"depth":2},"hidpi":{"type":"header","text":"HiDPI","value":"hidpi","line":31,"column":0,"depth":2},"application-support":{"type":"header","text":"Application support","value":"application-support","line":44,"column":0,"depth":3},"natural-scrolling":{"type":"header","text":"Natural scrolling","value":"natural-scrolling","line":59,"column":0,"depth":2}},"children":["dkfh510xhhdkee9koyvnfc0","jnkkl73dpn706gt3h04lvzw"],"parent":"0dcz8bz1ladgjebaljq61w7","data":{}},"body":"<h1 id=\"sway\">Sway<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#sway\"></a></h1>\n<h1 id=\"sway---i3-compatible-wayland-compositor\">Sway - i3-compatible Wayland compositor<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#sway---i3-compatible-wayland-compositor\"></a></h1>\n<blockquote>\n<p><a href=\"https://github.com/swaywm/sway\">https://github.com/swaywm/sway</a></p>\n</blockquote>\n<ul>\n<li><a href=\"#sway---i3-compatible-wayland-compositor\">Sway - i3-compatible Wayland compositor</a>\n<ul>\n<li><a href=\"#install\">Install</a></li>\n<li><a href=\"#config\">Config</a></li>\n<li><a href=\"#hidpi\">HiDPI</a>\n<ul>\n<li><a href=\"#application-support\">Application support</a></li>\n</ul>\n</li>\n<li><a href=\"#natural-scrolling\">Natural scrolling</a></li>\n</ul>\n</li>\n</ul>\n<h2 id=\"install\">Install<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#install\"></a></h2>\n<pre><code>sudo apt install sway\n</code></pre>\n<h2 id=\"config\">Config<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#config\"></a></h2>\n<blockquote>\n<p>Compatible with i3wm</p>\n</blockquote>\n<ul>\n<li>location: <code>~/.config/sway/config</code></li>\n</ul>\n<h2 id=\"hidpi\">HiDPI<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#hidpi\"></a></h2>\n<blockquote>\n<p><a href=\"https://github.com/swaywm/sway/wiki#hidpi\">https://github.com/swaywm/sway/wiki#hidpi</a></p>\n</blockquote>\n<ul>\n<li>show output settings\n<pre><code>swaymsg -t get_output\n</code></pre>\n</li>\n</ul>\n<pre><code>output &#x3C;id> &#x3C;config\n</code></pre>\n<h3 id=\"application-support\">Application support<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#application-support\"></a></h3>\n<ul>\n<li>already support:\n<ul>\n<li>telegram-desktop</li>\n<li>alacrity </li>\n</ul>\n</li>\n<li>Chrome:\n<ul>\n<li>chrome://flags</li>\n<li>Preferred Ozone platform => Wayland</li>\n</ul>\n</li>\n<li>Vscode\n<ul>\n<li>command flags:\n<ul>\n<li>--enable-features=UseOzonePlatform --ozone-platform=wayland  </li>\n<li>--ozone-platform-hint=auto</li>\n<li>--enable-features=WaylandWindowDecorations</li>\n</ul>\n</li>\n<li><a href=\"https://wiki.archlinux.org/title/Visual_Studio_Code#Running_natively_under_Wayland\">https://wiki.archlinux.org/title/Visual_Studio_Code#Running_natively_under_Wayland</a>  </li>\n</ul>\n</li>\n</ul>\n<h2 id=\"natural-scrolling\">Natural scrolling<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#natural-scrolling\"></a></h2>\n<blockquote>\n<p><a href=\"https://wiki.archlinux.org/title/sway\">https://wiki.archlinux.org/title/sway</a></p>\n</blockquote>\n<ul>\n<li>get inputs\n<pre><code>swaymsg -t get_inputs\n</code></pre>\n</li>\n<li>edit the config file\n<pre><code>input type:touchpad {\n  tap enabled\n  natural_scroll enabled\n}\n</code></pre>\n</li>\n</ul>\n<hr>\n<strong>Children</strong>\n<ol>\n<li><a href=\"/notes/dkfh510xhhdkee9koyvnfc0\">Fcitx5</a></li>\n</ol>","noteIndex":{"id":"xfkxbponh0sohobo6pual15","title":"Root","desc":"","updated":1668137379975,"created":1663481872547,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"cb44915142ec96bef8f764f3dc90389e","links":[],"anchors":{"welcome-to-my-page":{"type":"header","text":"Welcome to my page","value":"welcome-to-my-page","line":7,"column":0,"depth":1},"contacts":{"type":"header","text":"Contacts","value":"contacts","line":12,"column":0,"depth":2},"dendron":{"type":"header","text":"Dendron","value":"dendron","line":18,"column":0,"depth":2}},"children":["u5a2e2vvfn3x7k0shuvmb1b","qw8y69zxn8wr7tzz4gtcrrv","q7qw45jglqwmynary64q67c","6wjqcjgkrpeqtmzb1o8o1q8","3ervbn5we7t8v2l2vwtx847","4qi2z0z9fquupbd651xausx","sencgim78q74o1zuyvy1vz7","ue4oml1si982t3mmbthyxi9","zrogwjgtze8ne5joqpz8ty9","oesia0lbzh03fsoy124ck0k","el3p9zjue6h3b6zsl9oejkt","t5grkmcwvu4nl43igsj4gxz"],"parent":null,"data":{},"body":"# Welcome to my page\n\n- This is a place where I write my knowledge in both Vietnamese and English.\n- Please feel free to correct me if there is anything not right.\n\n## Contacts\n\n- [Github](https://github.com/thanhpp)\n- [Discord](https://discord.gg/ugNRjFNqjp)\n- [LinkedIn](https://www.linkedin.com/in/thanhpp/)\n\n## Dendron\n\n- [Home Page](https://wiki.dendron.so/)"},"collectionChildren":null,"customHeadContent":null,"config":{"version":5,"dev":{"enablePreviewV2":true,"enableSelfContainedVaults":true},"commands":{"lookup":{"note":{"selectionMode":"extract","confirmVaultOnCreate":true,"vaultSelectionModeOnCreate":"alwaysPrompt","leaveTrace":false,"bubbleUpCreateNew":true,"fuzzThreshold":0.2}},"randomNote":{},"insertNoteLink":{"aliasMode":"none","enableMultiSelect":false},"insertNoteIndex":{"enableMarker":false},"copyNoteLink":{"a