{"pageProps":{"note":{"id":"z2hgvaw2rpz93g3ije3zxmd","title":"Arch","desc":"","updated":1678415449403,"created":1669695426013,"custom":{},"fname":"linux.arch","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"edc201afa3f9a855a1a951bd82c4c64b","links":[],"anchors":{"arch-linux":{"type":"header","text":"Arch linux","value":"arch-linux","line":7,"column":0,"depth":1},"install":{"type":"header","text":"Install","value":"install","line":9,"column":0,"depth":2},"sound-card-not-found":{"type":"header","text":"Sound card not found","value":"sound-card-not-found","line":14,"column":0,"depth":2},"freeze-youtube-firefox--chrome---can-not-play-video-with-sound":{"type":"header","text":"Freeze youtube (firefox & chrome) - Can not play video with sound","value":"freeze-youtube-firefox--chrome---can-not-play-video-with-sound","line":26,"column":0,"depth":2},"dark-theme":{"type":"header","text":"Dark theme","value":"dark-theme","line":43,"column":0,"depth":2},"natural-scrolling":{"type":"header","text":"Natural scrolling","value":"natural-scrolling","line":51,"column":0,"depth":2}},"children":["qtktd7329d9m69svdgniohf","j8n4v1ohwrnlfm37verspi6","tbz5axmptocdnvjci817klz"],"parent":"6wjqcjgkrpeqtmzb1o8o1q8","data":{}},"body":"<h1 id=\"arch\">Arch<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#arch\"></a></h1>\n<h1 id=\"arch-linux\">Arch linux<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#arch-linux\"></a></h1>\n<h2 id=\"install\">Install<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#install\"></a></h2>\n<ul>\n<li><a href=\"https://wiki.archlinux.org/title/installation_guide\">https://wiki.archlinux.org/title/installation_guide</a></li>\n<li><a href=\"https://itsfoss.com/install-arch-linux/\">https://itsfoss.com/install-arch-linux/</a></li>\n</ul>\n<h2 id=\"sound-card-not-found\">Sound card not found<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#sound-card-not-found\"></a></h2>\n<blockquote>\n<p><a href=\"https://bbs.archlinux.org/viewtopic.php?id=262135\">https://bbs.archlinux.org/viewtopic.php?id=262135</a>\n<a href=\"https://wiki.archlinux.org/title/Advanced_Linux_Sound_Architecture#ALSA_Firmware\">https://wiki.archlinux.org/title/Advanced_Linux_Sound_Architecture#ALSA_Firmware</a></p>\n</blockquote>\n<ul>\n<li>Install ALSA firmware\n<pre><code>sudo pacman -S sof-firmware\nsudo pacman -S alsa-ucm-conf\n</code></pre>\n</li>\n</ul>\n<h2 id=\"freeze-youtube-firefox--chrome---can-not-play-video-with-sound\">Freeze youtube (firefox &#x26; chrome) - Can not play video with sound<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#freeze-youtube-firefox--chrome---can-not-play-video-with-sound\"></a></h2>\n<blockquote>\n<p><a href=\"https://bbs.archlinux.org/viewtopic.php?id=155714\">https://bbs.archlinux.org/viewtopic.php?id=155714</a>\n<a href=\"https://bbs.archlinux.org/viewtopic.php?id=274229\">https://bbs.archlinux.org/viewtopic.php?id=274229</a></p>\n</blockquote>\n<pre><code>$ systemctl --user status pulseaudio\n    dbus-org.bluez.service NOT FOUND ERROR\n</code></pre>\n<ul>\n<li>\n<p>Install ffmpeg</p>\n</li>\n<li>\n<p>Install vulkan: <a href=\"https://archlinux.org/packages/?name=vulkan-intel\">https://archlinux.org/packages/?name=vulkan-intel</a></p>\n</li>\n<li>\n<p>Install pipewire</p>\n<ul>\n<li><a href=\"https://www.reddit.com/r/archlinux/comments/lv5ihv/what_is_the_most_proper_way_to_replace_pulseaudio/\">https://www.reddit.com/r/archlinux/comments/lv5ihv/what_is_the_most_proper_way_to_replace_pulseaudio/</a></li>\n</ul>\n</li>\n</ul>\n<h2 id=\"dark-theme\">Dark theme<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#dark-theme\"></a></h2>\n<blockquote>\n<p><a href=\"https://wiki.archlinux.org/title/GTK#Dark_theme_variant\">https://wiki.archlinux.org/title/GTK#Dark_theme_variant</a></p>\n</blockquote>\n<ul>\n<li>GTK\n<ul>\n<li>gtk: <code>gtk-application-prefer-dark-theme = true</code></li>\n<li>gtk4: <code>gsettings set org.gnome.desktop.interface color-scheme prefer-dark</code></li>\n</ul>\n</li>\n</ul>\n<h2 id=\"natural-scrolling\">Natural scrolling<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#natural-scrolling\"></a></h2>\n<blockquote>\n<p><a href=\"https://bbs.archlinux.org/viewtopic.php?id=240950\">https://bbs.archlinux.org/viewtopic.php?id=240950</a></p>\n</blockquote>\n<pre><code># /etc/X11/xorg.conf.d/40-libinput.conf || /usr/share/X11/xorg.conf.d/40-libinput.conf\n\nOption \"NaturalScrolling\" \"true\"\n</code></pre>\n<hr>\n<strong>Children</strong>\n<ol>\n<li><a href=\"/notes/qtktd7329d9m69svdgniohf\">Corrupted Db</a></li>\n<li><a href=\"/notes/j8n4v1ohwrnlfm37verspi6\">Font</a></li>\n<li><a href=\"/notes/tbz5axmptocdnvjci817klz\">Pipewire</a></li>\n</ol>","noteIndex":{"id":"xfkxbponh0sohobo6pual15","title":"Root","desc":"","updated":1668137379975,"created":1663481872547,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"cb44915142ec96bef8f764f3dc90389e","links":[],"anchors":{"welcome-to-my-page":{"type":"header","text":"Welcome to my page","value":"welcome-to-my-page","line":7,"column":0,"depth":1},"contacts":{"type":"header","text":"Contacts","value":"contacts","line":12,"column":0,"depth":2},"dendron":{"type":"header","text":"Dendron","value":"dendron","line":18,"column":0,"depth":2}},"children":["u5a2e2vvfn3x7k0shuvmb1b","qw8y69zxn8wr7tzz4gtcrrv","q7qw45jglqwmynary64q67c","6wjqcjgkrpeqtmzb1o8o1q8","3ervbn5we7t8v2l2vwtx847","4qi2z0z9fquupbd651xausx","sencgim78q74o1zuyvy1vz7","ue4oml1si982t3mmbthyxi9","zrogwjgtze8ne5joqpz8ty9","oesia0lbzh03fsoy124ck0k","el3p9zjue6h3b6zsl9oejkt","t5grkmcwvu4nl43igsj4gxz"],"parent":null,"data":{},"body":"# Welcome to my page\n\n- This is a place where I write my knowledge in both Vietnamese and English.\n- Please feel free to correct me if there is anything not right.\n\n## Contacts\n\n- [Github](ht