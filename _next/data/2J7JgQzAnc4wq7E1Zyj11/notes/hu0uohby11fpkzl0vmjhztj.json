{"pageProps":{"note":{"id":"hu0uohby11fpkzl0vmjhztj","title":"Dynamodb","desc":"","updated":1662734584249,"created":1662729084337,"custom":{},"fname":"database.dynamodb","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"e7f0afa73f2b984803238fc4693554f1","links":[{"type":"wiki","from":{"fname":"database.dynamodb","id":"hu0uohby11fpkzl0vmjhztj","vaultName":"docs"},"value":"database.no-sql","position":{"start":{"line":6,"column":3,"offset":43},"end":{"line":6,"column":22,"offset":62},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"database.no-sql"}}],"anchors":{"dynamodb---amazon-dynamodb":{"type":"header","text":"DynamoDB - Amazon DynamoDB","value":"dynamodb---amazon-dynamodb","line":8,"column":0,"depth":1},"intro":{"type":"header","text":"Intro","value":"intro","line":10,"column":0,"depth":2},"features":{"type":"header","text":"Features","value":"features","line":16,"column":0,"depth":2},"ref":{"type":"header","text":"Ref","value":"ref","line":29,"column":0,"depth":2}},"children":[],"parent":"qw8y69zxn8wr7tzz4gtcrrv","data":{}},"body":"<h1 id=\"dynamodb\">Dynamodb<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#dynamodb\"></a></h1>\n<h1 id=\"dynamodb---amazon-dynamodb\">DynamoDB - Amazon DynamoDB<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#dynamodb---amazon-dynamodb\"></a></h1>\n<h2 id=\"intro\">Intro<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#intro\"></a></h2>\n<ul>\n<li><a href=\"/notes/7kfh5gzgi0chi9t1l4mi0sd\">No SQL</a></li>\n<li>High performance &#x26; scalable</li>\n<li>AWS service</li>\n</ul>\n<h2 id=\"features\">Features<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#features\"></a></h2>\n<ul>\n<li>Supports key-value &#x26; document data models</li>\n<li>Low latency\n<ul>\n<li>in-mem cache (DAX - DynamoDB accelerator)</li>\n</ul>\n</li>\n<li>Automated global replication</li>\n<li>Serverless: automatically scales table \n<ul>\n<li>maintains performance with zero administration</li>\n</ul>\n</li>\n<li>ACID <strong>server-side</strong> transactions </li>\n<li>Encryption at rest\n<ul>\n<li>ecrypts all customer data by default</li>\n<li>using the AWS Key Management Services </li>\n</ul>\n</li>\n</ul>\n<h2 id=\"ref\">Ref<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#ref\"></a></h2>\n<ul>\n<li><a href=\"https://viblo.asia/p/gioi-thieu-ve-dynamodb-phan-1-jamoG87nMz8P\">https://viblo.asia/p/gioi-thieu-ve-dynamodb-phan-1-jamoG87nMz8P</a></li>\n<li><a href=\"https://aws.amazon.com/dynamodb/?trk=87a194f5-c061-453e-83fa-8ad315ab0688&#x26;sc_channel=ps&#x26;s_kwcid=AL!4422!3!536393758042!e!!g!!dynamodb&#x26;ef_id=Cj0KCQjwyOuYBhCGARIsAIdGQROmE0VQWdVOp_rHFCfhlb3f_BTyKWliYmIgtPOby7bPeopEm4XtAZ0aAqeLEALw_wcB:G:s&#x26;s_kwcid=AL!4422!3!536393758042!e!!g!!dynamodb\">https://aws.amazon.com/dynamodb/?trk=87a194f5-c061-453e-83fa-8ad315ab0688&#x26;sc_channel=ps&#x26;s_kwcid=AL!4422!3!536393758042!e!!g!!dynamodb&#x26;ef_id=Cj0KCQjwyOuYBhCGARIsAIdGQROmE0VQWdVOp_rHFCfhlb3f_BTyKWliYmIgtPOby7bPeopEm4XtAZ0aAqeLEALw_wcB:G:s&#x26;s_kwcid=AL!4422!3!536393758042!e!!g!!dynamodb</a></li>\n</ul>","noteIndex":{"id":"xfkxbponh0sohobo6pual15","title":"Root","desc":"","updated":1668137379975,"created":1663481872547,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"cb44915142ec96bef8f764f3dc90389e","links":[],"anchors":{"welcome-to-my-page":{"type":"header","text":"Welcome to my page","value":"welcome-to-my-page","line":7,"column":0,"depth":1},"contacts":{"type":"header","text":"Contacts","value":"contacts","line":12,"column":0,"depth":2},"dendron":{"type":"header","text":"Dendron","value":"dendron","line":18,"column":0,"depth":2}},"children":["u5a2e2vvfn3x7k0shuvmb1b","qw8y69zxn8wr7tzz4gtcrrv","q7qw45jglqwmynary64q67c","6wjqcjgkrpeqtmzb1o8o1q8","3ervbn5we7t8v2l2vwtx847","4qi2z0z9fquupbd651xausx","sencgim78q74o1zuyvy1vz7