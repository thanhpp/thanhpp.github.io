{"pageProps":{"note":{"id":"h35nie9w3zmz2g2pgjuezhy","title":"Supervisord","desc":"","updated":1661644185295,"created":1661642884247,"custom":{},"fname":"linux.service.supervisord","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"dd4e978d468839f197e035c2bea336a3","links":[],"anchors":{"supervisord-a-process-control-system":{"type":"header","text":"Supervisord: A Process Control System","value":"supervisord-a-process-control-system","line":8,"column":0,"depth":1},"install":{"type":"header","text":"Install","value":"install","line":12,"column":0,"depth":2},"configuration-files":{"type":"header","text":"Configuration files","value":"configuration-files","line":16,"column":0,"depth":2},"command":{"type":"header","text":"Command","value":"command","line":32,"column":0,"depth":2}},"children":[],"parent":"tdn31rcl0l8818om4d2uj9s","data":{}},"body":"<h1 id=\"supervisord\">Supervisord<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#supervisord\"></a></h1>\n<h1 id=\"supervisord-a-process-control-system\">Supervisord: A Process Control System<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#supervisord-a-process-control-system\"></a></h1>\n<blockquote>\n<p><a href=\"http://supervisord.org/\">http://supervisord.org/</a></p>\n</blockquote>\n<h2 id=\"install\">Install<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#install\"></a></h2>\n<ul>\n<li>Ubuntu: <code>sudo apt install supervisor</code></li>\n</ul>\n<h2 id=\"configuration-files\">Configuration files<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#configuration-files\"></a></h2>\n<ul>\n<li>Folder: <code>/etc/supervisor/supervisord.conf</code></li>\n<li>Files: <code>/etc/supervisor/conf.d/*.conf</code></li>\n<li>Program config\n<pre><code>[program:&#x3C;program name>]\ncommand=&#x3C;absolute or relative>\nautostart=&#x3C;true/false>\nautorestart=&#x3C;true/false/unexpected>\nuser=&#x3C;username>\nstdout_logfile=&#x3C;/var/log/supervisord/...>\nstderr_logfile=&#x3C;/var/log/supervisord/...>\ndirectory=&#x3C;exec folder>\n</code></pre>\n</li>\n</ul>\n<h2 id=\"command\">Command<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#command\"></a></h2>\n<ul>\n<li>Enter the supervisord controller mode: <code>sudo supervisorctl</code></li>\n<li>Get status: <code>sudo supervisorctl status all</code></li>\n<li>Reload config: <code>sudo supervisorctl update</code>\n<ul>\n<li>add/remove config</li>\n<li>restart affected program</li>\n</ul>\n</li>\n<li>Read logs: <code>sudo supervisorctl tail -f &#x3C;program name> [stdout|stderr]</code></li>\n<li>Restart a service: <code>sudo supervisorctl restart &#x3C;program name></code></li>\n</ul>","noteIndex":{"id":"xfkxbponh0sohobo6pual15","title":"Root","desc":"","updated":1668137379975,"created":1663481872547,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":".","selfContained":true,"name":"docs"},"contentHash":"cb44915142ec96bef8f764f3dc90389e","links":[],"anchors":{"welcome-to-my-page":{"type":"header","text":"Welcome to my page","value":"welcome-to-my-page","line":7,"column":0,"depth":1},"contacts":{"type":"header","text":"Contacts","value":"contacts","line":12,"column":0,"depth":2},"dendron":{"type":"header","text":"Dendron","value":"dendron","line":18,"column":0,"depth":2}},"children":["u5a2e2vvfn3x7k0shuvmb1b","qw8y69zxn8wr7tzz4gtcrrv","q7qw45jglqwmynary64q67c","6wjqcjgkrpeqtmzb1o8o1q8","3ervbn5we7t8v2l2vwtx847","4qi2z0z9fquupbd651xausx","sencgim78q74o1zuyvy1vz7","ue4oml1si982t3mmbthyxi9","zrogwjgtze8ne5joqpz8ty9","oesia0lbzh03fsoy124ck0k","el3p9zjue6h3b6zsl9oejkt","t5grkmcwvu4nl43igsj4gxz"],"parent":null,"data":{},"body":"# Welcome to my page\n\n- This is a place where I write my knowledge in both Vietnamese and English.\n- Please feel free to correct me if there is anything not right.\n\n## Contacts\n\n- [Github](https://github.com/thanhpp)\n- [Discord](https://discord.gg/ugNRjFNqjp)\n- [Li